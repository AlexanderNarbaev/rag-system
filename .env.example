# ───── RAG Proxy Configuration ─────
# Copy to proxy/.env: cp .env.example proxy/.env
# All model names are REQUIRED — no hardcoded defaults.
# Uncomment and set appropriate values for your deployment.

# ── Qdrant (vector database) ────────────────────────────────────────────────
QDRANT_HOST=localhost           # Qdrant server hostname
QDRANT_PORT=6333                # Qdrant HTTP API port
COLLECTION_NAME=knowledge_base  # Primary collection for hybrid search

# ── Embedding model ─────────────────────────────────────────────────────────
#        Dense + sparse multilingual embeddings
# Example candidates:
#   BAAI/bge-m3                    — 1024-dim, 8K context, multilingual
#   intfloat/multilingual-e5-large — 1024-dim, 512 context
#   sentence-transformers/all-MiniLM-L6-v2 — 384-dim, lightweight (<100MB)
EMBEDDER_MODEL=                 # REQUIRED — set before first run
EMBEDDER_DEVICE=cpu             # Use "cuda" for GPU acceleration

# ── Reranker / Cross-Encoder ────────────────────────────────────────────────
# Example candidates:
#   cross-encoder/ms-marco-MiniLM-L-6-v2  — fast, 512 context, ~90 MB
#   BAAI/bge-reranker-v2-m3               — multilingual, 8192 context
#   mixedbread-ai/mxbai-rerank-large-v1   — high quality, 512 context
RERANKER_MODEL=                 # REQUIRED — set before first run
RERANKER_MAX_LENGTH=512         # Max token length per chunk
RERANKER_BATCH_SIZE=32          # Batch size for reranker inference

# ── LLM / Primary Language Model ────────────────────────────────────────────
# Supports OpenAI-compatible API (vLLM, llama.cpp, Ollama, LiteLLM, etc.)
# Example candidates:
#   gemma-4-26b-it               — Google, 130K context, strong multilingual
#   meta-llama/Llama-3.1-70B     — Meta, 128K context
#   mistralai/Mixtral-8x22B      — Mistral, 64K context, MoE
#   Qwen/Qwen2.5-72B-Instruct    — Alibaba, 128K context
LLM_ENDPOINT=http://localhost:8000/v1  # OpenAI-compatible endpoint
LLM_MODEL_NAME=                 # REQUIRED — set before first run
LLM_API_KEY=                    # API key (leave empty if none)
REQUEST_TIMEOUT=120             # Timeout in seconds for LLM calls
MAX_RETRIES=3                   # Retry attempts on failure
RETRY_DELAY=1.0                 # Delay between retries (seconds)

# ── SLM / Small Language Model (routing, decomposition) ─────────────────────
# Leave SLM_ENDPOINT empty to disable SLM (heuristic fallback used)
# Example candidates:
#   gemma-2b-it                  — Google, 8K context, fast
#   Qwen/Qwen2.5-1.5B-Instruct   — Alibaba, 32K context
#   microsoft/Phi-3-mini-4k-instruct — Microsoft, 4K context
SLM_ENDPOINT=                   # Leave empty to disable SLM features
SLM_MODEL_NAME=
SLM_API_KEY=
SLM_MAX_TOKENS=256

# ── Retrieval parameters ────────────────────────────────────────────────────
MAX_CHUNKS_RETRIEVAL=50         # Chunks fetched from Qdrant before reranking
MAX_CHUNKS_AFTER_RERANK=20      # Chunks passed to LLM after reranking

# ── Redis cache ─────────────────────────────────────────────────────────────
USE_REDIS=false                 # Enable semantic cache lookup
REDIS_URL=redis://localhost:6379

# ── LangGraph agentic orchestration ─────────────────────────────────────────
USE_LANGGRAPH=false             # Enable multi-step retrieval loops
MAX_RETRIEVAL_LOOPS=3           # Max iteration count for LangGraph agent

# ── Neo4j graph knowledge base ──────────────────────────────────────────────
GRAPH_ENABLED=false             # Enable GraphRAG expansion
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=                 # REQUIRED if GRAPH_ENABLED=true — CHANGE in production
USE_GRAPH_EXPANSION=false       # Entity-based graph traversal

# ── Authentication ──────────────────────────────────────────────────────────
AUTH_ENABLED=false              # Enable JWT authentication
JWT_SECRET=change-me-in-production  # REQUIRED if AUTH_ENABLED=true (min 32 bytes for HS256)
JWT_ALGORITHM=HS256             # HS256 (local) or RS256 (Keycloak/OIDC)
TOKEN_EXPIRE_HOURS=24           # Access token lifetime (hours)
ACCESS_TOKEN_MINUTES=60         # Short-lived access token (minutes)

# ── User Database ───────────────────────────────────────────────────────────
USER_DB_PATH=./data/users.db    # SQLite database for users, refresh tokens, blacklist
BCRYPT_ROUNDS=12                # Password hashing rounds (higher = slower, more secure)
REFRESH_TOKEN_DAYS=30           # Refresh token lifetime (days)

# ── RBAC ────────────────────────────────────────────────────────────────────
RBAC_ENABLED=false              # Enable role-based access control

# ── Keycloak / OIDC (optional) ──────────────────────────────────────────────
# KEYCLOAK_URL=                 # Keycloak base URL (enables RS256 OIDC mode)
# KEYCLOAK_REALM=rag            # Keycloak realm name
# KEYCLOAK_CLIENT_ID=rag-proxy  # Keycloak client ID
# JWT_PUBLIC_KEY=               # PEM public key for RS256 (auto-discovered from Keycloak)

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_REQUESTS=false              # Log incoming requests
LOG_DIR=./logs

# ── Observability ───────────────────────────────────────────────────────────
METRICS_ENABLED=true
LOG_FORMAT=text                 # "json" or "text"

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
RELOAD=false                    # Enable hot reload (dev only)
WORKERS=1

# ── Confidence Scoring ───────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.5         # Min confidence score before escalation
MAX_VERIFY_LOOPS=2               # Max retry loops for VERIFY_CASCADE

# ── Self-Enrichment ──────────────────────────────────────────────────────────
ENRICHMENT_ENABLED=false         # Feed accepted Q&A back into knowledge base

# ── Admin Alerts ─────────────────────────────────────────────────────────────
ADMIN_ALERT_ENABLED=false        # Alert admins on low-confidence answers
ADMIN_ALERT_ENDPOINT=            # Webhook URL or email endpoint for alerts

# ── Tools / Function Calling ─────────────────────────────────────────────────
TOOLS_ENABLED=false              # Enable tool calling support
LIVE_SOURCES_ENABLED=false       # Enable live source tools (Confluence, Jira, GitLab)
TOOLS_PARALLEL_EXECUTION=true    # Execute independent tools in parallel
TOOLS_MAX_CONCURRENCY=10         # Max concurrent tool executions
TOOLS_DECLARATIVE_DIR=./tools/declarative  # Directory for YAML/JSON tool definitions
# TOOLS_OPENAPI_SPECS='[{"name":"petstore","url":"https://example.com/openapi.json","mode":"auto"}]'

# ── Live Source APIs ─────────────────────────────────────────────────────────
# Required when LIVE_SOURCES_ENABLED=true
CONFLUENCE_API_URL=              # Confluence base URL (e.g. https://confluence.company.com)
CONFLUENCE_API_TOKEN=            # Confluence API token
JIRA_API_URL=                    # Jira base URL (e.g. https://jira.company.com)
JIRA_API_TOKEN=                  # Jira API token
GITLAB_API_URL=                  # GitLab base URL (e.g. https://gitlab.company.com)
GITLAB_API_TOKEN=                # GitLab API token

# ── MCP Server ───────────────────────────────────────────────────────────────
# MCP_TRANSPORT=stdio            # Transport type: "stdio" or "http"
# MCP_PORT=8081                  # HTTP port for MCP server (when using HTTP transport)
# MCP_HOST=0.0.0.0               # HTTP bind address for MCP server

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ENDPOINT=localhost:9000    # MinIO S3 API endpoint (host:port)
MINIO_ACCESS_KEY=minioadmin      # MinIO root user
MINIO_SECRET_KEY=minioadmin      # MinIO root password (CHANGE in production)
MINIO_BUCKET=rag-artifacts       # Bucket for model artifacts (MLflow)
MINIO_DOCS_BUCKET=rag-documents  # Bucket for uploaded documents
MINIO_SECURE=false               # Use HTTPS for MinIO connection
