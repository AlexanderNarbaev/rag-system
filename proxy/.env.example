# ───── RAG Proxy — Configuration Template ─────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env with real secrets to version control!

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=knowledge_base

# ── Embedding (e.g., bge-m3) ─────────────────────────────────────────────────
EMBEDDER_MODEL=bge-m3
EMBEDDER_ENDPOINT=
EMBEDDER_API_KEY=
EMBEDDER_FALLBACK_LOCAL=true

# ── Reranker (e.g., bge-reranker-v2-m3) ─────────────────────────────────────
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_ENDPOINT=
RERANKER_API_KEY=
RERANKER_FALLBACK_LOCAL=true
RERANKER_MAX_LENGTH=8192

# ── ETL Remote Services ──────────────────────────────────────────────────────
# The ETL pipeline reads the same EMBEDDER_* and RERANKER_* env vars above
# (via etl_config.yaml ${VAR:-default} placeholders) to connect to remote
# GPUStack-hosted models instead of running local sentence-transformers.
# Additional ETL-only overrides:
# EMBEDDER_ENDPOINT=              (same as proxy)
# EMBEDDER_MODEL=BAAI/bge-m3      (note: full HF name)
# RERANKER_ENDPOINT=              (rerank-specific path)
# SLM_ENDPOINT=                   (lightweight model for entity extraction)
# SLM_MODEL=qwen2.5-3b

# ── LLM (any OpenAI-compatible endpoint) ─────────────────────────────────────
LLM_ENDPOINT=http://localhost:8000/v1
LLM_MODEL_NAME=
LLM_API_KEY=
LLM_PROVIDER_TYPE=openai
REQUEST_TIMEOUT=120
MAX_RETRIES=3
RETRY_DELAY=1.0

# ── SLM (Small Language Model for routing/decomposition) ─────────────────────
SLM_ENDPOINT=
SLM_MODEL_NAME=
SLM_API_KEY=
SLM_MAX_TOKENS=256

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set to true for production. Disable only for local dev.
AUTH_ENABLED=true
JWT_SECRET=
# Generate: openssl rand -hex 32
JWT_ALGORITHM=HS256
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Services ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
GRAPH_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

LOG_LEVEL=INFO
LOG_FORMAT=text

# ── Conversation Memory ──────────────────────────────────────────────────────
CLARIFICATION_ENABLED=true
CONVERSATION_MAX_TURNS=10
CONVERSATION_SUMMARY_THRESHOLD_TOKENS=2000

# ── Stale Document Detection ─────────────────────────────────────────────────
STALE_DETECTION_ENABLED=true
STALE_CONFLUENCE_DAYS=90
STALE_JIRA_DAYS=30
STALE_GITLAB_DAYS=14

# ── Reindex Scheduler ────────────────────────────────────────────────────────
REINDEX_ENABLED=true
REINDEX_CHECK_INTERVAL=3600
REINDEX_STALENESS_THRESHOLD=80
REINDEX_MAX_CONCURRENT_TASKS=5

# ── Knowledge Integrity Validation ───────────────────────────────────────────
INTEGRITY_CHECK_ENABLED=true
INTEGRITY_NLI_CONTRADICTION_THRESHOLD=0.7
INTEGRITY_CHUNK_SAMPLE_LIMIT=200

# ── Progressive Retrieval ────────────────────────────────────────────────────
PROGRESSIVE_RETRIEVAL_ENABLED=true
PROGRESSIVE_RETRIEVAL_STAGES=5,10,20

# ── Qdrant Performance Tuning ────────────────────────────────────────────────
QDRANT_QUANTIZATION_ENABLED=false
QDRANT_GRPC_ENABLED=false
QDRANT_GRPC_PORT=6334
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=100

# ── Ungrounded Generation ────────────────────────────────────────────────────
ALLOW_UNGROUNDED_GENERATION=true

# ── OCR (Document Image Extraction) ──────────────────────────────────────────
OCR_ENABLED=true
OCR_LANGUAGES=rus+eng
OCR_CONFIDENCE_THRESHOLD=60

# ── ETL Secret — ETL → Proxy admin API authentication ────────────────────────
# Auto-generated on first startup and persisted to data/.etl_secret.
# Set a persistent value for production. Generate with: openssl rand -hex 32
# ETL_SECRET=

# ── ETL WAL ──────────────────────────────────────────────────────────────────
WAL_BACKEND=file
