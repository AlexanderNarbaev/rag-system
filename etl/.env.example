# ───── ETL Pipeline Configuration ─────
# Copy to etl/.env: cp etl/.env.example etl/.env

# ── Confluence extractor ────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://confluence.example.com
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACES=              # Comma-separated space keys (e.g. ENG,DEV)
CONFLUENCE_PAGE_LIMIT=500       # Max pages per extraction run

# ── Jira extractor ──────────────────────────────────────────────────────────
JIRA_BASE_URL=https://jira.example.com
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECTS=                  # Comma-separated project keys
JIRA_ISSUE_LIMIT=1000           # Max issues per extraction run

# ── GitLab extractor ────────────────────────────────────────────────────────
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_PRIVATE_TOKEN=
GITLAB_PROJECT_IDS=             # Comma-separated project IDs
GITLAB_REF=main                 # Branch/tag to extract docs from

# ── Chunker ─────────────────────────────────────────────────────────────────
CHUNK_STRATEGY=semantic         # "semantic", "sliding_window", or "hybrid"
CHUNK_SIZE=512                  # Target chunk size in tokens
CHUNK_OVERLAP=64                # Token overlap between chunks
EMBEDDER_MODEL=BAAI/bge-m3      # Model used for hash-based versioning

# ── Qdrant indexer ──────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=knowledge_base
BATCH_SIZE=64                   # Embedding batch size
MAX_RETRIES=3                   # Retry on upsert failure

# ── Neo4j graph builder ─────────────────────────────────────────────────────
GRAPH_ENABLED=false             # Enable entity extraction + graph import
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=                 # REQUIRED if GRAPH_ENABLED=true — CHANGE in production

# ── WAL / checkpointing ─────────────────────────────────────────────────────
WAL_DIR=./wal                   # Write-ahead log directory
CHECKPOINT_INTERVAL=100         # Save checkpoint every N chunks
RESUME_ON_FAILURE=true          # Resume from last checkpoint on restart

# ── Scheduler ───────────────────────────────────────────────────────────────
SCHEDULE_ENABLED=false          # Enable periodic ETL runs
SCHEDULE_INTERVAL_MINUTES=360   # Run interval (6 hours default)
FULL_RESYNC=false               # Force full re-index (ignore WAL)

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR
LOG_DIR=./logs
LOG_MAX_BYTES=10485760           # 10 MB per log file
LOG_BACKUP_COUNT=5              # Keep 5 rotated log files
