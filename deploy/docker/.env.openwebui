# ═══════════════════════════════════════════════════════════════════════════════
# .env.openwebui — OpenWebUI Configuration for Corporate RAG System
# ═══════════════════════════════════════════════════════════════════════════════
# Version: 2.1.0
# Purpose: Standalone OpenWebUI deployment with PostgreSQL, Redis, Tika
# Requires: already running RAG Proxy (proxy/docker-compose.yml)
#
# ════════════ REQUIRED SETTINGS ═════════════════════════════════════════════════
# Before first run, you must set:
#   WEBUI_SECRET_KEY  — generate via scripts/init-openwebui.sh
#   POSTGRES_PASSWORD — PostgreSQL database password
# ═══════════════════════════════════════════════════════════════════════════════

# ── OpenWebUI Core ─────────────────────────────────────────────────────────────
# Secret key for JWT signing and session encryption
# Generate: openssl rand -hex 32
WEBUI_SECRET_KEY=REQUIRED_GENERATE_VIA_INIT_SCRIPT

# System name (displayed in title and branding)
WEBUI_NAME=Корпоративный RAG-ассистент

# ── PostgreSQL Database ─────────────────────────────────────────────────────────
POSTGRES_USER=openwebui
# DB password — must be set before first run (minimum 16 characters)
POSTGRES_PASSWORD=REQUIRED_GENERATE_VIA_INIT_SCRIPT
POSTGRES_DB=openwebui

# PostgreSQL performance parameters
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE=768MB
PG_MAINTENANCE_WORK_MEM=64MB
PG_WAL_BUFFERS=16MB
PG_MAX_CONNS=100
PG_MAX_WAL_SIZE=2GB
PG_MIN_WAL_SIZE=80MB

# Application-side connection pool parameters
DATABASE_POOL_SIZE=15
DATABASE_POOL_MAX_OVERFLOW=20
# User activity status update interval (seconds)
DATABASE_USER_ACTIVE_STATUS_UPDATE_INTERVAL=300

# ── Redis (WebSocket sessions) ──────────────────────────────────────────────────
REDIS_MAXMEMORY=256mb
WEBSOCKET_MANAGER=redis

# ── Authentication (corporate requirements) ────────────────────────────────────
# Enable authentication
WEBUI_AUTH=true

# DISABLE self-registration — only admin can create accounts
ENABLE_SIGNUP=false

# Enable login via username/password form
ENABLE_LOGIN_FORM=true

# Default role: "pending" — admin must approve the account
DEFAULT_USER_ROLE=pending

# Enable initial admin signup (first-run only — must be disabled manually after admin creation)
ENABLE_INITIAL_ADMIN_SIGNUP=true

# ── RAG Proxy Connection (OpenAI-compatible API) ────────────────────────────────
# Enable OpenAI API
ENABLE_OPENAI_API=true

# RAG Proxy URL as OpenAI-compatible backend
# Format: http://rag-proxy:8080/v1  (rag-proxy — service name in rag-network)
OPENAI_API_BASE_URLS=http://rag-proxy:8080/v1

# API keys for each URL (use ; separator for multiple URLs)
OPENAI_API_KEYS=REQUIRED_GENERATE_VIA_INIT_SCRIPT

# Disable direct connections (only via configured URLs)
ENABLE_DIRECT_CONNECTIONS=false

# ── Ollama — DISABLED (air-gapped, models via proxy) ────────────────────────────
ENABLE_OLLAMA_API=false

# ── Models ──────────────────────────────────────────────────────────────────────
# Default models (identifiers as in proxy /v1/models)
DEFAULT_MODELS=rag

# Lightweight model for: title generation, tags, search queries
TASK_MODEL=rag

# ── Built-in RAG — DISABLED (using RAG proxy) ───────────────────────────────────
# Proxy handles: hybrid search, reranking, graph expansion, confidence scoring
RAG_ENABLED=false

# When using built-in RAG (RAG_ENABLED=true) — set engine and model:
# RAG_EMBEDDING_ENGINE=openai
# RAG_EMBEDDING_MODEL=BAAI/bge-m3
# RAG_OPENAI_API_BASE_URL=http://rag-proxy:8080/v1
# RAG_OPENAI_API_KEY=sk-rag-proxy

# ── File Storage MinIO (S3-compatible) ──────────────────────────────────────────
# Using shared MinIO from rag-network, but separate bucket: openwebui-files
STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=REQUIRED_GENERATE_VIA_INIT_SCRIPT
S3_SECRET_ACCESS_KEY=REQUIRED_GENERATE_VIA_INIT_SCRIPT
S3_BUCKET_NAME=openwebui-files
S3_REGION_NAME=us-east-1
S3_ADDRESSING_STYLE=path

# ── Document Content Extraction (Apache Tika) ───────────────────────────────────
CONTENT_EXTRACTION_ENGINE=tika
TIKA_SERVER_URL=http://tika:9998
# Maximum uploaded file size (bytes) — 100 MB
FILE_UPLOAD_SIZE_LIMIT=104857600

# ── Security ────────────────────────────────────────────────────────────────────
# Secure session cookies (enable with HTTPS; disable for HTTP only)
WEBUI_SESSION_COOKIE_SECURE=true

# CORS — allowed request origins
# For production, specify a concrete domain instead of *
CORS_ALLOW_ORIGIN=http://localhost:3000

# ── Air-Gapped / Offline Mode ────────────────────────────────────────────────────
# Disable all external calls: telemetry, auto-update, checks
OFFLINE_MODE=true
RAG_EMBEDDING_MODEL_AUTO_UPDATE=false

# ── Telemetry — FULLY DISABLED ──────────────────────────────────────────────────
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# ── Concurrency Settings ────────────────────────────────────────────────────────
# Single worker to protect shared state (OpenWebUI recommendation)
UVICORN_WORKERS=1
# Thread pool for parallel processing
THREAD_POOL_SIZE=500
# Port inside container (do not change)
PORT=8080

# ── Container Resource Limits ───────────────────────────────────────────────────
# OpenWebUI
OPENWEBUI_HOST_PORT=3000
OPENWEBUI_CPU_LIMIT=2
OPENWEBUI_MEM_LIMIT=2G
OPENWEBUI_CPU_RESERVE=0.5
OPENWEBUI_MEM_RESERVE=512M

# PostgreSQL
POSTGRES_CPU_LIMIT=2
POSTGRES_MEM_LIMIT=1G
POSTGRES_CPU_RESERVE=0.25
POSTGRES_MEM_RESERVE=256M

# Redis
REDIS_CPU_LIMIT=1
REDIS_MEM_LIMIT=512M
REDIS_CPU_RESERVE=0.1
REDIS_MEM_RESERVE=64M

# Tika
TIKA_CPU_LIMIT=2
TIKA_MEM_LIMIT=1G
TIKA_CPU_RESERVE=0.25
TIKA_MEM_RESERVE=256M
TIKA_HEAP_SIZE=512m
