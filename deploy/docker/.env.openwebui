# ═══════════════════════════════════════════════════════════════════════════════
# .env.openwebui — Конфигурация OpenWebUI для корпоративной RAG-системы
# ═══════════════════════════════════════════════════════════════════════════════
# Версия: 2.0.0
# Назначение: Автономное развертывание OpenWebUI с PostgreSQL, Redis, Tika
# Требуется: уже запущенный RAG Proxy (proxy/docker-compose.yml)
#
# ════════════ ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ ═══════════════════════════════════════════
# Перед первым запуском обязательно задайте:
#   WEBUI_SECRET_KEY  — сгенерируйте через scripts/init-openwebui.sh
#   POSTGRES_PASSWORD — пароль базы данных PostgreSQL
# ═══════════════════════════════════════════════════════════════════════════════

# ── Ядро OpenWebUI ─────────────────────────────────────────────────────────────
# Секретный ключ для подписи JWT и шифрования сессий
# Сгенерируйте: openssl rand -hex 32
WEBUI_SECRET_KEY=

# Название системы (отображается в заголовке и брендинге)
WEBUI_NAME=Корпоративный RAG-ассистент

# ── База данных PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=openwebui
# Пароль БД — обязательно задать перед запуском (минимум 16 символов)
POSTGRES_PASSWORD=
POSTGRES_DB=openwebui

# Параметры производительности PostgreSQL
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE=768MB
PG_MAINTENANCE_WORK_MEM=64MB
PG_WAL_BUFFERS=16MB
PG_MAX_CONNS=100
PG_MAX_WAL_SIZE=2GB
PG_MIN_WAL_SIZE=80MB

# Параметры пула соединений на стороне приложения
DATABASE_POOL_SIZE=15
DATABASE_POOL_MAX_OVERFLOW=20
# Интервал обновления статуса активности пользователей (сек)
DATABASE_USER_ACTIVE_STATUS_UPDATE_INTERVAL=300

# ── Redis (сессии WebSocket) ───────────────────────────────────────────────────
REDIS_MAXMEMORY=256mb
WEBSOCKET_MANAGER=redis

# ── Аутентификация (корпоративные требования) ──────────────────────────────────
# Включить аутентификацию
WEBUI_AUTH=true

# ЗАПРЕТИТЬ самостоятельную регистрацию — только администратор создает аккаунты
ENABLE_SIGNUP=false

# Разрешить вход через форму логин/пароль
ENABLE_LOGIN_FORM=true

# Роль по умолчанию: "pending" — администратор должен подтвердить учетную запись
DEFAULT_USER_ROLE=pending

# Разрешить первичную регистрацию администратора (однократно при первом запуске)
# После создания администратора эта опция автоматически отключается
ENABLE_INITIAL_ADMIN_SIGNUP=true

# ── Подключение к RAG Proxy (OpenAI-совместимый API) ───────────────────────────
# Включаем OpenAI API
ENABLE_OPENAI_API=true

# URL RAG Proxy как OpenAI-совместимого бэкенда
# Формат: http://rag-proxy:8080/v1  (rag-proxy — имя сервиса в rag-network)
OPENAI_API_BASE_URLS=http://rag-proxy:8080/v1

# API-ключи для каждого из URL (через ; если несколько URL)
OPENAI_API_KEYS=sk-rag-proxy

# Запрещаем прямые подключения (только через настроенные URL)
ENABLE_DIRECT_CONNECTIONS=false

# ── Ollama — ОТКЛЮЧЕН (air-gapped, модели через прокси) ────────────────────────
ENABLE_OLLAMA_API=false

# ── Модели ─────────────────────────────────────────────────────────────────────
# Модели по умолчанию (идентификаторы как в /v1/models прокси)
DEFAULT_MODELS=rag

# Легковесная модель для задач: генерация заголовков, тегов, поисковых запросов
TASK_MODEL=rag

# ── Встроенный RAG — ОТКЛЮЧЕН (используем RAG прокси) ───────────────────────────
# Прокси выполняет: гибридный поиск, реранкинг, графовое расширение, оценку достоверности
RAG_ENABLED=false

# При использовании встроенного RAG (RAG_ENABLED=true) — укажите движок и модель:
# RAG_EMBEDDING_ENGINE=openai
# RAG_EMBEDDING_MODEL=BAAI/bge-m3
# RAG_OPENAI_API_BASE_URL=http://rag-proxy:8080/v1
# RAG_OPENAI_API_KEY=sk-rag-proxy

# ── Хранилище файлов MinIO (S3-совместимое) ────────────────────────────────────
# Используем общий MinIO из rag-network, но отдельный бакет: openwebui-files
STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=openwebui-files
S3_REGION_NAME=us-east-1
S3_ADDRESSING_STYLE=path

# ── Извлечение содержимого документов (Apache Tika) ────────────────────────────
CONTENT_EXTRACTION_ENGINE=tika
TIKA_SERVER_URL=http://tika:9998
# Максимальный размер загружаемого файла (байты) — 100 МБ
FILE_UPLOAD_SIZE_LIMIT=104857600

# ── Безопасность ───────────────────────────────────────────────────────────────
# Secure-куки для сессий (включить при HTTPS; выключить если только HTTP)
WEBUI_SESSION_COOKIE_SECURE=false

# CORS — разрешенные источники запросов
# Для production укажите конкретный домен вместо *
CORS_ALLOW_ORIGIN=http://localhost:3000

# ── Режим работы без интернета (air-gapped) ────────────────────────────────────
# Отключаем все внешние вызовы: телеметрию, автообновление, проверки
OFFLINE_MODE=true
RAG_EMBEDDING_MODEL_AUTO_UPDATE=false

# ── Телеметрия — ПОЛНОСТЬЮ ОТКЛЮЧЕНА ──────────────────────────────────────────
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# ── Настройки конкурентности ───────────────────────────────────────────────────
# Один воркер для защиты разделяемого состояния (рекомендация OpenWebUI)
UVICORN_WORKERS=1
# Пул потоков для параллельной обработки
THREAD_POOL_SIZE=2000
# Порт внутри контейнера (не менять)
PORT=8080

# ── Лимиты ресурсов контейнеров ────────────────────────────────────────────────
# OpenWebUI
OPENWEBUI_HOST_PORT=3000
OPENWEBUI_CPU_LIMIT=2
OPENWEBUI_MEM_LIMIT=2G
OPENWEBUI_CPU_RESERVE=0.5
OPENWEBUI_MEM_RESERVE=512M

# PostgreSQL
POSTGRES_CPU_LIMIT=2
POSTGRES_MEM_LIMIT=1G
POSTGRES_CPU_RESERVE=0.25
POSTGRES_MEM_RESERVE=256M

# Redis
REDIS_CPU_LIMIT=1
REDIS_MEM_LIMIT=512M
REDIS_CPU_RESERVE=0.1
REDIS_MEM_RESERVE=64M

# Tika
TIKA_CPU_LIMIT=2
TIKA_MEM_LIMIT=1G
TIKA_CPU_RESERVE=0.25
TIKA_MEM_RESERVE=256M
TIKA_HEAP_SIZE=512m
